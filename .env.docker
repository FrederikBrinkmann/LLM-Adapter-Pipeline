# Environment variables for Docker deployment
# Copy this file to .env and fill in the values

# OpenAI API Key (required for OpenAI models)
OPENAI_API_KEY=your-openai-api-key-here

# LLM Model Configuration
LLM_PIPELINE_LLM_MODEL_IDS=["gpt-5.2","gpt-5.1","gpt-5","gpt-5-mini","gpt-5-nano","o3","o4-mini","llama3.1:8b","llama3:latest","qwen3:8b","qwen3:4b","gemma2:9b","phi3:mini","mistral:7b"]
LLM_PIPELINE_LLM_DEFAULT_MODEL=gpt-5.2

# Target Ticket Service (inside Docker network)
LLM_PIPELINE_TARGET_API_BASE_URL=http://ticket_service:9000
LLM_PIPELINE_TARGET_API_TICKETS_PATH=/tickets
LLM_PIPELINE_AUTO_SUBMIT_ENABLED=true
LLM_PIPELINE_AUTO_SUBMIT_ALLOW_MISSING_FIELDS=true

# Optional: Ollama host (if running Ollama outside Docker)
OLLAMA_HOST=http://host.docker.internal:11434

# ===========================================
# Mail Ingest Configuration (optional)
# ===========================================
# Starten mit: docker compose --profile with-mail up -d
MAIL_IMAP_HOST=imap.ionos.de
MAIL_IMAP_PORT=993
MAIL_IMAP_USER=your-email@example.com
MAIL_IMAP_PASSWORD=your-password-here
MAIL_IMAP_FOLDER=INBOX
MAIL_POLL_INTERVAL=30
MAIL_MODEL_ID=gpt-5.2
